# === DATABASE (PostgreSQL - Neon) ===
# Ottieni la connection string da https://console.neon.tech
DATABASE_URL=

# === STRIPE ===
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === RESEND (Email) ===
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=

# === APP ===
NEXT_PUBLIC_URL=http://localhost:3000

# === ADMIN NOTIFICATIONS ===
# Email che riceve la notifica di nuovi ordini
ADMIN_NOTIFY_EMAIL=

# === AUTH ===
# Per JWT: openssl rand -base64 32
AUTH_SECRET=

# === SHIPPING ===
# Soglia di subtotale (in centesimi) per la spedizione gratuita.
# Server-side (usato dal backend per determinare se applicare la spedizione).
FREE_SHIPPING_THRESHOLD=15000
# Stessa soglia esposta al client (per il messaggio nel carrello).
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=15000

# === RATE LIMIT (opzionale, produzione) ===
# Per multi-instance serverless (Vercel) si consiglia Upstash Redis.
# Se non configurati, il rate-limit usa memoria locale (inefficace cross-instance).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
